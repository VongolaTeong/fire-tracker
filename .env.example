# Copy to `.env` (gitignored) for reference, or export these as real environment
# variables before running. NEVER commit real credentials.
#
# Spring does not auto-load `.env`; this file documents the variables the app reads.
# For local runs you can instead rely on the localhost defaults baked into
# application.yml, or create a gitignored src/main/resources/application-local.yml.

# JDBC URL of the Postgres database
DATABASE_URL=jdbc:postgresql://localhost:5432/firetracker
DATABASE_USERNAME=firetracker
DATABASE_PASSWORD=changeme

# HTTP port. Hosts like Render inject PORT in production; defaults to 8080 locally.
PORT=8080

# Daily market-data ingestion (price/FX pull). Off by default so dev/CI/tests never hit the
# external feeds; set to true in production to enable the scheduled job.
APP_MARKET_DATA_SCHEDULING_ENABLED=false
